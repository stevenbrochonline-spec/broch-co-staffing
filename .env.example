# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# Admin login credentials. The admin user is seeded/updated from these on boot.
# If either is missing, NO admin user is created and admin login is disabled.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Set to "production" in production so the session cookie is marked Secure (HTTPS only).
# Leave unset locally so the cookie works over http://localhost.
# NODE_ENV=production
