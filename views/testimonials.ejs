<!DOCTYPE html>
<html lang="en">
<head>
    <title>Testimonials | Trusted Household &amp; Childcare</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <section class="testimonials-hero">
        <span class="eyebrow">Testimonials</span>
        <h1>Trusted by Families Worldwide</h1>
        <p>For over two decades, private families have trusted us to introduce household and childcare professionals with discretion, care, and lasting results. These are some of their words.</p>
        <hr class="gold-divider">
    </section>

    <%
      var featured = testimonials.find(function (t) { return t.featured; });
      var others = testimonials.filter(function (t) { return !t.featured; });
    %>

    <% if (featured) { %>
    <section class="featured-testimonial">
        <div class="featured-inner">
            <div class="featured-aside">
                <div class="stars" role="img" aria-label="Rated 5 out of 5 stars"><span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
                <p class="featured-label"><%= featured.label %></p>
            </div>
            <figure class="featured-content">
                <span class="featured-quote-mark" aria-hidden="true">&ldquo;</span>
                <blockquote class="featured-quote"><%= featured.quote %></blockquote>
                <ul class="trust-highlights">
                    <li><span class="trust-check" aria-hidden="true">&#10003;</span> Together for 2 years</li>
                    <li><span class="trust-check" aria-hidden="true">&#10003;</span> Nanny became part of our family</li>
                    <li><span class="trust-check" aria-hidden="true">&#10003;</span> Published with explicit client consent</li>
                </ul>
            </figure>
        </div>
    </section>
    <% } %>

    <section class="testimonials-section">
        <div class="testimonial-grid">
            <% others.forEach(function(t) { %>
            <figure class="testimonial-card">
                <div class="stars" role="img" aria-label="Rated 5 out of 5 stars"><span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
                <span class="card-quote-mark" aria-hidden="true">&ldquo;</span>
                <blockquote><%= t.quote %></blockquote>
                <figcaption>
                    <span class="client-label"><%= t.label %></span>
                    <% if (t.location) { %><span class="client-location"><%= t.location %></span><% } %>
                </figcaption>
            </figure>
            <% }); %>
        </div>
    </section>

    <section class="trust-metrics" aria-label="Why families trust us">
        <div class="trust-metrics-grid">
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"></circle><path d="M9 14.5 7.5 21l4.5-2.5 4.5 2.5-1.5-6.5"></path></svg></span>
                <p class="metric-title">25+ Years Experience</p>
            </div>
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="m8.5 12 2.5 2.5 4.5-5"></path></svg></span>
                <p class="metric-title">Hundreds of Successful Placements</p>
            </div>
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z"></path></svg></span>
                <p class="metric-title">International Expertise</p>
            </div>
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l4 4v14H6z"></path><path d="M14 3v4h4M9 12h6M9 16h6"></path></svg></span>
                <p class="metric-title">Candidate References</p>
            </div>
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l4 4v14H6z"></path><path d="M14 3v4h4"></path><path d="m9 14 1.8 1.8L14 12"></path></svg></span>
                <p class="metric-title">Additional Client References</p>
            </div>
            <div class="metric-card">
                <span class="metric-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0"></path><path d="M4 13v3a2 2 0 0 0 2 2h1v-5H6a2 2 0 0 0-2 2Zm16 0v3a2 2 0 0 1-2 2h-1v-5h1a2 2 0 0 1 2 2Z"></path></svg></span>
                <p class="metric-title">Ongoing Support</p>
            </div>
        </div>
    </section>

    <section class="references-section">
        <p class="references-note">To protect our clients&rsquo; privacy, most testimonials are shared anonymously.</p>
        <p class="references-note">Additional client references and recommendation letters are available upon request.</p>

        <aside class="references-box">
            <h2>Need additional reassurance?</h2>
            <p>For privacy reasons, many of our clients prefer not to publish their names publicly.</p>
            <p>We are happy to provide additional client references and recommendation letters directly to serious prospective clients upon request.</p>
        </aside>
    </section>

    <section class="cta-section">
        <h2>Ready to find the right person for your home?</h2>
        <p>Book a consultation and we will prepare a private shortlist for your family.</p>
        <a href="/book" class="cta-btn">Book a consultation</a>
    </section>

    <%- include('partials/footer') %>
</body>
</html>
