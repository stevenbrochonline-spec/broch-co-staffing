<!DOCTYPE html>
<html lang="en">
<head>
    <title>Exclusive Candidate Shortlist | Trusted Household &amp; Childcare</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <section class="page-hero">
        <h1>Exclusive Candidate Shortlist</h1>
        <p>A private, curated preview of household and childcare professionals — personally reviewed and screened, with reference checks where available.</p>
    </section>

    <section class="protection-note">
        <p>To protect candidate privacy and maintain a professional process, direct contact details are not published. Full CV, reference details, and direct introductions are coordinated only through Trusted Household &amp; Childcare after consultation.</p>
    </section>

    <section class="candidates-section">
        <div class="candidate-grid">
            <% candidates.forEach(function(c) { %>
            <article class="candidate-card">
                <div class="candidate-head">
                    <div class="candidate-avatar" aria-hidden="true"><%= c.displayName.charAt(0) %></div>
                    <div>
                        <h3><%= c.displayName %></h3>
                        <p class="candidate-role"><%= c.role %></p>
                    </div>
                    <span class="candidate-status status-<%= c.status.toLowerCase().split(' ')[0] %>"><%= c.status %></span>
                </div>

                <ul class="candidate-meta">
                    <li><span>Experience</span><%= c.yearsExperience %> years</li>
                    <li><span>Languages</span><%= c.languages.join(', ') %></li>
                    <li><span>Availability</span><%= c.availabilityRegion %></li>
                </ul>

                <div class="skill-tags">
                    <% c.skills.slice(0, 5).forEach(function(s) { %><span class="tag"><%= s %></span><% }); %>
                </div>

                <p class="trust-note"><%= c.trustNote %></p>

                <div class="cv-locked" aria-label="CV preview locked">
                    <div class="cv-lines"><span></span><span></span><span></span><span></span></div>
                    <div class="cv-lock-overlay">
                        <span class="cv-lock-icon">&#128274;</span>
                        <span>Full CV available through Trusted Household &amp; Childcare</span>
                    </div>
                </div>

                <div class="candidate-actions">
                    <a href="/candidates/<%= c.slug %>" class="card-link">View profile &rarr;</a>
                    <a href="/book" class="cta-btn">Request shortlist access</a>
                </div>
            </article>
            <% }); %>
        </div>
    </section>

    <section class="cta-section">
        <h2>Looking for someone specific?</h2>
        <p>Tell us about your family and we will prepare a private shortlist matched to your needs.</p>
        <a href="/contact" class="cta-btn">Discuss your requirements</a>
    </section>

    <%- include('partials/footer') %>
</body>
</html>
