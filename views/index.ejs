<!DOCTYPE html>
<html lang="en">
<head>
    <title>Broch & Co. | Elite Household Staffing</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <header class="hero">
        <div class="hero-content">
            <h1 id="hero-title">Elite Staffing Solutions</h1>
            <p id="hero-sub">Providing premium Filipino household professionals for discerning families in Georgia and Armenia.</p>
            <a href="/book" class="cta-btn" id="hero-cta">Book Consultation</a>
        </div>
    </header>

    <section class="services-preview">
        <h2 class="section-title">Our Services</h2>
        <div class="services-grid">
            <div class="card">
                <div class="card-icon">&#128118;</div>
                <h3 id="card1-title">Professional Nannies</h3>
                <p id="card1-desc">English-speaking specialists focusing on child development, safety, and cultural education.</p>
                <a href="/services" class="card-link">Learn More &rarr;</a>
            </div>
            <div class="card">
                <div class="card-icon">&#127860;</div>
                <h3 id="card2-title">Private Chefs</h3>
                <p id="card2-desc">Expertise in Asian and International cuisines, managing household nutrition and events.</p>
                <a href="/services" class="card-link">Learn More &rarr;</a>
            </div>
            <div class="card">
                <div class="card-icon">&#127968;</div>
                <h3 id="card3-title">Executive Housekeepers</h3>
                <p id="card3-desc">Meticulous home management and organization according to 5-star hospitality standards.</p>
                <a href="/services" class="card-link">Learn More &rarr;</a>
            </div>
        </div>
    </section>

    <section class="why-us">
        <div class="why-grid">
            <div class="why-text">
                <h2>Why Broch & Co.?</h2>
                <div class="why-item">
                    <h4>Rigorous Vetting</h4>
                    <p>Every candidate undergoes background checks, skills assessments, and personal interviews before placement.</p>
                </div>
                <div class="why-item">
                    <h4>Full Legal Compliance</h4>
                    <p>We manage Georgia Worknet registration, Armenian work permits, and all visa documentation end to end.</p>
                </div>
                <div class="why-item">
                    <h4>Ongoing Support</h4>
                    <p>Dedicated account managers for the first 90 days and continuous check-ins throughout the placement.</p>
                </div>
            </div>
            <div class="why-image"></div>
        </div>
    </section>

    <section class="compliance">
        <div class="badge" id="badge-text">2026 Legal Framework</div>
        <h2 id="comp-title">Global Standards, Local Compliance</h2>
        <p id="comp-desc">We handle the entire 2026 Georgia Worknet registration and Armenian work permits. Headquartered in Dubai.</p>
    </section>

    <section class="cta-section">
        <h2>Ready to Find Your Perfect Household Professional?</h2>
        <p>Schedule a complimentary consultation with our placement specialists.</p>
        <a href="/book" class="cta-btn">Get Started</a>
    </section>

    <%- include('partials/footer') %>
</body>
</html>
