<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= candidate.displayName %> — <%= candidate.role %> | Trusted Household &amp; Childcare</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/nav') %>

    <%
        var primaryHref = candidate.profileType === 'real_placed' ? '/contact' : '/book';
        var secondaryCta = {
            real_available: { label: 'Request introduction', href: '/contact' },
            real_placed: { label: 'Discuss your household needs', href: '/book' },
            representative: { label: 'Discuss similar candidates', href: '/contact' }
        }[candidate.profileType];
        var bannerText = {
            real_available: 'Available for consultation. Introductions are arranged through Trusted Household & Childcare after consultation.',
            real_placed: 'Currently placed with a family and not available. This profile is shown to illustrate the type of household talent we place — we can introduce similar available candidates.',
            representative: 'Representative profile — an illustrative example of the level and type of household talent we review. Introductions are arranged through Trusted Household & Childcare.'
        }[candidate.profileType];
        // yearsExperience may be a number (e.g. 8) or a descriptive string (e.g. "7+ years ...").
        var expText = (typeof candidate.yearsExperience === 'number') ? candidate.yearsExperience + ' years’ experience' : candidate.yearsExperience;
        var expMeta = (typeof candidate.yearsExperience === 'number') ? candidate.yearsExperience + ' years' : candidate.yearsExperience;
    %>

    <section class="page-hero">
        <h1><%= candidate.displayName %></h1>
        <p><%= candidate.role %> &middot; <%= expText %></p>
    </section>

    <section class="candidate-profile">
        <div class="profile-banner type-<%= candidate.profileType.replace('real_', '') %>">
            <strong><%= candidate.statusLabel %>.</strong> <%= bannerText %>
        </div>

        <div class="profile-grid">
            <aside class="profile-side">
                <% if (candidate.photoUrl) { %>
                <img class="candidate-photo large" src="<%= candidate.photoUrl %>" alt="<%= candidate.photoAlt || 'Candidate photo' %>">
                <% } else { %>
                <div class="candidate-avatar large" aria-hidden="true"><%= candidate.displayName.charAt(0) %></div>
                <% } %>
                <span class="candidate-status status-<%= candidate.profileType.replace('real_', '') %>"><%= candidate.statusLabel %></span>

                <ul class="candidate-meta">
                    <li><span>Role</span><%= candidate.role %></li>
                    <% if (candidate.nationality) { %><li><span>Nationality</span><%= candidate.nationality %></li><% } %>
                    <li><span><%= candidate.profileType === 'real_placed' ? 'Placement region' : 'Availability' %></span><%= candidate.availabilityRegion %></li>
                    <li><span>Experience</span><%= expMeta %></li>
                    <li><span>Languages</span><%= candidate.languages.join(', ') %></li>
                    <li><span>Childcare</span><%= candidate.childcareExperience %></li>
                </ul>

                <% if (Array.isArray(candidate.trustNotes)) { %>
                <ul class="trust-note-list">
                    <% candidate.trustNotes.forEach(function(n) { %><li><%= n %></li><% }); %>
                </ul>
                <% } else { %>
                <p class="trust-note"><%= candidate.trustNotes %></p>
                <% } %>

                <a href="<%= primaryHref %>" class="cta-btn full"><%= candidate.ctaLabel %></a>
                <a href="<%= secondaryCta.href %>" class="card-link"><%= secondaryCta.label %> &rarr;</a>
            </aside>

            <div class="profile-main">
                <div class="profile-section">
                    <h2>About</h2>
                    <p><%= candidate.shortBio %></p>
                </div>

                <div class="profile-section">
                    <h2>Household experience</h2>
                    <p><%= candidate.householdExperience %></p>
                </div>

                <div class="profile-section">
                    <h2>CV summary</h2>
                    <p><%= candidate.cvSummary %></p>
                </div>

                <div class="profile-section">
                    <h2>Work history</h2>
                    <% if (Array.isArray(candidate.workHistorySummary)) { %>
                    <ul class="profile-list">
                        <% candidate.workHistorySummary.forEach(function(w) { %><li><%= w %></li><% }); %>
                    </ul>
                    <% } else { %>
                    <p><%= candidate.workHistorySummary %></p>
                    <% } %>
                </div>

                <div class="profile-section">
                    <h2>Skills</h2>
                    <div class="skill-tags">
                        <% candidate.skills.forEach(function(s) { %><span class="tag"><%= s %></span><% }); %>
                    </div>
                </div>

                <div class="profile-section">
                    <h2>Recommendation excerpt</h2>
                    <blockquote class="reco-excerpt"><%= candidate.recommendationExcerpt %></blockquote>
                    <p class="muted">References are available through Trusted Household &amp; Childcare.</p>
                </div>

                <div class="cv-locked wide" aria-label="CV preview locked">
                    <div class="cv-lines"><span></span><span></span><span></span><span></span><span></span></div>
                    <div class="cv-lock-overlay">
                        <span class="cv-lock-icon">&#128274;</span>
                        <span>Full CV and recommendation letter available through Trusted Household &amp; Childcare</span>
                    </div>
                </div>

                <div class="protection-note inline">
                    <p>Public profiles are intentionally limited to protect candidate privacy and maintain a professional introduction process. Full CVs, reference details, and direct introductions are coordinated only through Trusted Household &amp; Childcare after consultation.</p>
                    <p class="protection-sub">Some profiles may be representative examples or currently placed candidates, shown to illustrate the level and type of household talent we review.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <% if (candidate.profileType === 'real_placed') { %>
        <h2>Looking for someone like <%= candidate.displayName %>?</h2>
        <p><%= candidate.displayName %> is currently placed. We can introduce you to similar available candidates after a consultation.</p>
        <a href="/contact" class="cta-btn"><%= candidate.ctaLabel %></a>
        <% } else if (candidate.profileType === 'representative') { %>
        <h2>Like this profile?</h2>
        <p>This is a representative example. Request a private shortlist of similar candidates matched to your household.</p>
        <a href="/book" class="cta-btn"><%= candidate.ctaLabel %></a>
        <% } else { %>
        <h2>Interested in <%= candidate.displayName %>?</h2>
        <p>Book a consultation and we will coordinate a private introduction.</p>
        <a href="/book" class="cta-btn"><%= candidate.ctaLabel %></a>
        <% } %>
    </section>

    <%- include('partials/footer') %>
</body>
</html>
